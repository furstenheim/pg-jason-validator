(1 row)

-- ignores arrays
SELECT additional_properties_1('[1,2,3]');
 additional_properties_1 
-------------------------
 t
(1 row)

-- ignores strings
SELECT additional_properties_1('"foobarbaz"');
 additional_properties_1 
-------------------------
 t
(1 row)

-- ignores other non-objects
SELECT additional_properties_1('12');
 additional_properties_1 
