-- if appears at the end when serialized (keyword processing sequence)
-- yes redirects to then and passes
SELECT if_v7_10('"yes"');
 if_v7_10 
----------
 t
(1 row)

-- other redirects to else and passes
SELECT if_v7_10('"other"');
